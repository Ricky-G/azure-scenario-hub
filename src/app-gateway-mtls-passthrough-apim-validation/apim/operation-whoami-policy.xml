<!--
  Operation policy: /whoami  (model-neutral trust probe).
  Runs AFTER the API-scope inbound (via <base/>), which already enforced the
  ACTIVE validation model and would have returned 403 if the certificate was
  not trusted. This operation applies NO per-client authorization, so it
  returns 200 for ANY certificate APIM trusts under the current model.

  This is the operation that shows the difference between the two models:
    * PINNED mode: only allow-listed certs (client1, client2) reach here.
      A CA-signed-but-unlisted cert (client3) is rejected upstream -> 403.
    * CHAIN  mode: any cert the Root CA actually signed reaches here, so
      client3 also returns 200.
-->
<policies>
  <inbound>
    <base />
    <return-response>
      <set-status code="200" reason="OK" />
      <set-header name="Content-Type" exists-action="override">
        <value>application/json</value>
      </set-header>
      <set-header name="X-Evidence-Decision" exists-action="override">
        <value>ALLOW</value>
      </set-header>
      <set-header name="X-Evidence-Mode" exists-action="override">
        <value>@((string)((Newtonsoft.Json.Linq.JObject)context.Variables["auth"])["mode"])</value>
      </set-header>
      <set-header name="X-Evidence-Client" exists-action="override">
        <value>@((string)((Newtonsoft.Json.Linq.JObject)context.Variables["auth"])["client"])</value>
      </set-header>
      <set-header name="X-Evidence-ChainOk" exists-action="override">
        <value>@(((Newtonsoft.Json.Linq.JObject)context.Variables["auth"])["chainOk"].ToString())</value>
      </set-header>
      <set-header name="X-Evidence-PinnedMatch" exists-action="override">
        <value>@(((Newtonsoft.Json.Linq.JObject)context.Variables["auth"])["pinnedMatch"].ToString())</value>
      </set-header>
      <set-body>@{
          var a = (Newtonsoft.Json.Linq.JObject)context.Variables["auth"];
          var o = new Newtonsoft.Json.Linq.JObject();
          o["decision"] = "ALLOW";
          o["mode"] = (string)a["mode"];
          o["client"] = (string)a["client"];
          o["message"] = "This certificate is trusted by APIM under the active validation model.";
          o["presentedThumbprint"] = (string)a["thumbprint"];
          o["presentedSubject"] = (string)a["subject"];
          o["issuerDnMatch"] = (bool)a["issuerDnMatch"];
          o["chainOk"] = (bool)a["chainOk"];
          o["pinnedMatch"] = (bool)a["pinnedMatch"];
          o["appGwVerify"] = (string)a["appGwVerify"];
          return o.ToString();
      }</set-body>
    </return-response>
  </inbound>
  <backend>
    <base />
  </backend>
  <outbound>
    <base />
  </outbound>
  <on-error>
    <base />
  </on-error>
</policies>
